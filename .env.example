# Copy to .env and fill in. .env is gitignored.
# `make install` reads env from the current shell; source this file before
# running if you put values here:  set -a; source .env; set +a

# --- Hugging Face (artifact downloads) -----------------------------------
# Both the bootstrap model and corpus are public — no auth required.
# HF_TOKEN is optional; set it if you hit rate limits or need private repos.
HF_TOKEN=

# Set WITH_CORPUS=1 to opt into the corpus download during `make install`.
# Leave unset/0 if you only need the bootstrap model.
WITH_CORPUS=0

# --- Dashboard -----------------------------------------------------------
# Flask session signing key for the monitoring dashboard. If unset, a random
# 32-byte key is generated per-process (fine for local dev; sessions won't
# survive a restart).
# HEXO_DASHBOARD_SECRET_KEY=
